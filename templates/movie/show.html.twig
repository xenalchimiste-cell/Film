{% extends 'base.html.twig' %}

{% block title %}Film{% endblock %}

{% block body %}
    <h1>Film</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ movie.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ movie.title }}</td>
            </tr>
            <tr>
                <th>Réalisateur</th>
                <td>{{ movie.director }}</td>
            </tr>
            <tr>
                <th>Année</th>
                <td>{{ movie.releaseYear }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ movie.synopsis }}</td>
            </tr>
            <tr>
                <th>Genre</th>
                <td>{{ movie.genres }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_movie_index') }}">Retour</a>

    <a href="{{ path('app_movie_edit', {'id': movie.id}) }}">Modifier</a>

    {{ include('movie/_delete_form.html.twig') }}
{% endblock %}
