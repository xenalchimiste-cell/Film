{% extends 'base.html.twig' %}

{% block title %}Movie index{% endblock %}

{% block body %}
    <h1>Movie index</h1>

<h1>Liste des films</h1>

<form method="GET" action="{{ path('app_movie_index') }}">

    <input 
        type="text" 
        name="title" 
        placeholder="Rechercher un film..."
        value="{{ title }}"
    >

        <button type="submit">
        Rechercher
        </button>
    {% if title %}
        <a class="btn" href="{{ path('app_movie_index') }}">
        Réinitialiser
        </a>
    {% endif %}
</form>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Realisateur</th>
                <th>Année</th>
                <th>Synopsis</th>
                <th>Genre</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for movie in movies %}
            <tr>
                <td>{{ movie.id }}</td>
                <td>{{ movie.title }}</td>
                <td>{{ movie.director }}</td>
                <td>{{ movie.releaseYear }}</td>
                <td>{{ movie.synopsis }}</td>
                <td>{{ movie.genres }}</td>
                <td>
                    <a href="{{ path('app_movie_show', {'id': movie.id}) }}">Voir</a>
                    <a href="{{ path('app_movie_edit', {'id': movie.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun film trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_movie_new') }}">Crée un film</a>
{% endblock %}
